# Example environment variables (do NOT commit secrets in .env.local)

# --- Blikk API credentials (server-side only) ---
BLIKK_APP_ID=
BLIKK_APP_SECRET=

# Optional overrides
BLIKK_BASE_URL=https://publicapi.blikk.com
BLIKK_TASKS_PATH=/v1/Core/Tasks
BLIKK_TASK_COMMENTS_PATH_TEMPLATE=/v1/Core/Tasks/{id}/Comments
BLIKK_TASK_COMMENT_BODY_KEY=text

# Debug
BLIKK_LOG_BODIES=false
BLIKK_UPDATES_DISABLED=false

# --- Supabase ---
# Public URL used by the app (also used for admin/service clients)
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side keys
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage
SUPABASE_BUCKET=pdfs

# --- Internal tasks ---
TASKS_DEFAULT_ASSIGNEE_UUID=

# --- Offert: kunduppgifter via länk (token-form) ---
# Email via Resend
RESEND_API_KEY=
MAIL_FROM=
# Receiver for notifications (Andreas)
OFFERT_CUSTOMER_NOTIFY_TO=

# Optional: extra pepper for hashing the token server-side
OFFERT_CUSTOMER_TOKEN_PEPPER=

# Optional: force correct public origin for links in emails
# (recommended in production)
NEXT_PUBLIC_SITE_URL=

# Next.js
NODE_ENV=development
